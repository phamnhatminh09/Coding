{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Build with MSYS2 G++ (UCRT64)",
        "type": "shell",
        "command": "C:/msys64/ucrt64/bin/g++.exe",
        "args": [
          "-g",
          "-std=c++20",
          "${file}",
          "-o",
          "${fileDirname}/${fileBasenameNoExtension}.exe"
        ],
        "options": {
          "cwd": "${fileDirname}"
        },
        "problemMatcher": ["$gcc"],
        "group": {
          "kind": "build",
          "isDefault": true
        }
      }
    ]
  }