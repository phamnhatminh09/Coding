<script src=https://cdnjs.cloudflare.com/ajax/libs/Swiper/4.2.2/js/swiper.min.js></script>
<script>
	var swiper = new Swiper(".swiper-container", {
		autoplay: true,
		disableOnInteraction: false,
		slidesPerView: 6,
		slidesPerColumn: 5,
		slidesPerGroup: 1,
		spaceBetween: 20,
		breakpoints: {
			  768: {
          slidesPerView: 3, // Show fewer slides
          grid: {
            rows: 2, // Reduce the number of rows
          },
          spaceBetween: 10, // Reduce spacing between slides
        },
		},
		pagination: {
			el: ".swiper-pagination",
			clickable: true,
			dynamicBullets: true
		},
		on: {
			init: function() {},
			orientationchange: function() {},
			beforeResize: function() {
				let vw = window.innerWidth;
				if (vw > 1000) {
					mySwiper.params.slidesPerView = 3;
					mySwiper.params.slidesPerColumn = 3;
					mySwiper.params.slidesPerGroup = 3
				} else {
					mySwiper.params.slidesPerView = 1;
					mySwiper.params.slidesPerColumn = 1;
					mySwiper.params.slidesPerGroup = 1
				}
				mySwiper.init()
			}
		}
	});
</script></div><div class="textwidget custom-html-widget">

