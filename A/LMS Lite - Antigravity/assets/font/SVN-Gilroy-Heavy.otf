			#services {
	background: #202221;
}
.tabcontent {
    display: none;
}
.tab-page{
	width: 600px;
}
@media only screen and (max-width: 780px) {
	.tab-page{
	width: 270px;
}
}

@media only screen and (max-width: 780px) {
#quytrinh .row {
	display: flex;
	flex-direction: column-reverse;
}
}
#vsg-img {
	margin-bottom: 20px;
}

#vsg-img:hover {
	box-shadow: rgba(149, 157, 165, 0.2) 0px 8px 24px;
}
.side-bar-tabs {
	position: sticky;
	top: 0;
	height: auto;
	z-index: 99;
}
.tabcontent iframe {
	position: relative;
	max-width: 848px;
}
.tabs {
	width: auto;
	margin-left: 22%;
	margin-right: 22%;
	display:flex;
	margin-bottom: 2rem;
	justify-content: center;
}
.tab {
	background: white;
	margin-right: 15px;
	padding: 1.2rem;
	border-radius: 8px;
}

div.tab button {
	background-color: unset;
	border: unset;
	white-space: nowrap;
}

div#tab23,div#tab24,div#tab25,div#tab26, div#tab21, div#tab22, div#tab29, div#tab30 {
	visibility: hidden;
}

.tab:active {
	background: #00aa54;
}

.tab:hover {
	background: #bed7b9;
}

.side-bar-tabs {
	padding-right: 2rem;
}

.sidetabcontent {
    display: none;
}
.side-content {
	padding-right: 2rem;
}
.sidetabs {
	width: auto;
	margin-left: 22%;
	margin-right: 22%;
	display:flex;
	margin-bottom: 2rem;
	justify-content: center;

}

.sidetab {
	background: white;
	white-space: nowrap;
		padding: 10px 15px;
    font-weight: 500;
    margin: 0;
	user-select: none;
}


.sidetab:active {
	background: #00aa54;
}

.sidetab:hover {
	background: #eaefe9;
}

#side-content-tab11 {
	display: block;
}
#dinhdang div.container {
	display: flex;
	flex-direction: row-reverse;
	justify-content: center;
	align-items: flex-start;
	overflow: visible;
}

@media only screen and (max-width: 468px) {
	#dinhdang div.container {
		flex-direction: column-reverse;
		align-items: center;
	}
	.tabcontent iframe {
	max-width: 290px;
		height: 200px;
}
	.tabcontent {
		margin-bottom: 2rem;
		justify-content: center;
		align-content: center;
	}
}
@media only screen and (min-width:469px) and (max-width: 1023px) {
	#dinhdang div.container {
		flex-direction: row-reverse;
	}
	.tabcontent iframe {
	max-width: 500px;
		height: 300px;
}
} 
/* gioi thieu ve OES */
 .video-wrapper {
	 position: relative;
	 padding-bottom: 56.25%;
	 height: 0;
	 overflow: hidden;
}
 .video-wrapper iframe {
	 position: absolute;
	 top:0;
	 left: 0;
	 width: 100%;
	 height: 100%;
}
 .ab-us .mgt-2 {
	 margin-top: 1em;
}
 .ab-us h3 {
	 text-transform: uppercase;
	 font-weight: 500;
}
 .ab-us .sm-1 {
	 display: flex;
}
 .ab-us .sm-1 img {
	 border-radius: 10px;
	 width: 100%;
}
 .ab-us .text img {
	 width: 4em;
	 display: initial;
}
 .ab-us .title-ab {
	 text-align: center;
}
 .ab-us .box, .ab-us .con-dv, .con-nb {
	 display: flex;
	 justify-content: space-between;
}
 .ab-us .gtc {
	 box-sizing: border-box;
	 padding: 0 30px 30px 30px;
	 display: inline-block;
	 text-align: center;
}
 .ab-us .gtc h5 {
	 border-bottom: 5px solid #87bc3c8c;
	 display: inline-block;
}
 .ab-us .mgt {
	 margin-top: 4em;
}
 .ab-us .mgb {
	 margin-bottom: 2em;
}
 .ab-us .box-dv {
	 border: 2px solid #87BC3C;
	 box-sizing: border-box;
	 padding: 30px;
	 display: inline-block;
	 text-align: center;
	 border-radius: 10px;
}
 .ab-us .upper {
	 text-transform: uppercase;
}
 .ab-us .icon img {
	 width: 7em;
}
 .ab-us .nb-box {
	 border: 2px solid #C4C4C4;
	 box-sizing: border-box;
	 padding: 30px;
	 display: inline-block;
	 text-align: center;
	 border-radius: 10px;
}
 .ab-us .nb-text {
	 color: #87BC3C;
	 font-weight: bold;
	 font-size: 2em;
}
 .ab-us .img-cus img {
	 width: 100%;
}
 @media (max-width: 767px) {
	/* For mobile phones: */
	 .ab-us {
		 margin: 0 20px;
	}
	 .sm-1 {
		 flex-direction: column;
	}
	 .ab-us .sm-1 .img {
		 width: 100%;
		 padding-right: 0;
	}
	 .ab-us .sm-1 .text {
		 width: 100%;
		 display: flex;
		 flex-direction: column;
		 align-items: center;
	}
	 .sm-1 .text p {
		 text-align: center;
		 margin: 0;
	}
	 .ab-us .text img {
		 padding-top: 1em;
	}
	 .ab-us .gtc {
		 width: 100%;
	}
	 .ab-us .box, .ab-us .con-dv, .con-nb {
		 flex-direction: column;
	}
	 .ab-us .box-dv {
		 width: 100%;
		 margin-bottom: 2rem;
	}
	 .ab-us .nb-box {
		 width: 100%;
		 margin-bottom: 2rem;
	}
}
 @media (min-width: 768px) {
	/* For desktop: */
	 .ab-us {
		 margin: 0 50px;
	}
	 .ab-us .sm-1 .img {
		 padding-right: 3em;
		 width: 60%;
	}
	 .ab-us .sm-1 .text {
		 width: 40%;
	}
	 .ab-us .text img {
		 padding-top: 4em;
	}
	 .ab-us .gtc {
		 width: 25%;
	}
	 .ab-us .box-dv {
		 width: 31%;
	}
	 .ab-us .nb-box {
		 width: 31%;
	}
}
/* gioi thieu ve OES */
/* USP */
 #moDau {
	 margin-right: 200px;
	 margin-left: 200px;
	 font-weight: 400;
	 font-size: 16px;
	 line-height: 24px;
	 padding-bottom: 50px;
	 padding-top: 20px;
}
 #chuyenNghiep {
	 display: flex;
	 padding-right: 50px;
	 margin-left: 20px;
}
 .cnleft {
	 font-weight: 500;
	 font-size: 14px;
	 line-height: 24px;
	 padding-left: 100px;
	 padding-right: 50px;
	 padding-top: 60px;
}
 #chuyenNghiep1 {
	 display: flex;
	 align-items: center;
	 font-weight: 500;
	 font-size: 14px;
	 line-height: 24px;
}
 #chuyenNghiep2 {
	 display: flex;
	 align-items: center;
	 font-weight: 500;
	 font-size: 14px;
	 line-height: 24px;
}
 .left {
	 align-items: left;
}
 #khachHang {
	 padding-bottom: 40px;
}
 .textkh {
	 font-weight: 400;
	 font-size: 16px;
	 line-height: 24px;
}
 #nhietHuyet {
	 display: flex;
	 padding-bottom: 40px;
	 padding-top: 40px;
}
 .nh1 {
	 width: 50%;
	 padding-left: 100px;
}
 .nh2 {
	 width: 50%;
	 text-align: right;
	 padding-right: 100px;
	 font-weight: 400;
	 font-size: 16px;
	 line-height: 24px;
	 display: grid;
	 align-content: center;
	 padding-top: 60px;
}
 #tinhTe {
	 display: flex;
	 padding-top: 40px;
}
 .tt1 {
	 width: 50% ;
	 padding-left: 100px;
	 padding-right: 100px;
	 font-weight: 400;
	 font-size: 16px;
	 line-height: 24px;
	 padding-top: 60px;
}
 .tt2 {
	 width: 50%;
	 padding-right: 100px;
}
 #sangTao {
	 display: flex;
}
 .st1 {
	 width: 50% ;
	 padding-left: 100px;
	 padding-right: 100px;
}
 .st2 {
	 width: 50%;
	 padding-right: 100px;
	 text-align: right;
	 font-weight: 400;
	 font-size: 16px;
	 line-height: 24px;
	 display: grid;
	 align-content: center;
	 padding-top: 60px;
}
 #hstOES {
	 font-weight: 500;
	 font-size: 20px;
	 line-height: 28px;
}
 #hst {
	 display: flex;
	 justify-content: space-evenly;
	 padding-bottom: 50px;
	 padding-left: 50px;
	 padding-right: 10px;
}
 #hst p {
	 margin: 0;
}
 .hst1 {
	 background-color: white;
	 border-radius: 16px;
	 box-shadow: 0px 1px 1px rgba(0, 0, 0, 0.14), 0px 2px 1px rgba(0, 0, 0, 0.12), 0px 1px 3px rgba(0, 0, 0, 0.2);
	 width: 324px;
	 display: grid;
	 justify-content: center;
	 padding-bottom: 20px;
	 margin-top: -10px;
}
 .hst2 {
	 display: flex;
	 align-items: center;
	 font-weight: 500;
	 font-size: 14px;
	 justify-content: center;
	 margin-bottom: -30px;
}
 .hst2 img {
	 margin:20px 0;
}
 .hst3 {
	 margin-bottom: -10px;
}
 .toiUu {
	 display: flex;
	 padding-top: 40px;
	 padding-bottom: 60px;
}
 .part1 {
	 width: 48%;
}
 .part2 {
	 padding-top: 100px;
}
 .part3 {
	 width: 48%;
}
 #toiUu1 {
	 padding-left: 100px;
	 padding-right: 100px;
}
 #dambao {
	 font-weight: 400;
	 font-size: 16px;
	 line-height: 24px;
}
 .toiUu2 {
	 display: flex;
	 justify-content: space-evenly;
	 margin-left: 80px;
}
 .tu1, .tu2 {
	 border: 2px solid rgba(0, 0, 0, 0.1);
	 border-radius: 16px;
	 width: 412px;
	 height: 204px;
	 padding: 20px;
	 padding-right: 90px;
}
 .ti-kh {
	 font-weight: 500;
	 line-height: 28px;
	 padding-left: 100px;
}
 .para {
	 padding-left:100px;
}
 .img-mgl {
	 margin-left: 100px;
}
 #khachHang img {
	 margin-left: 100px;
}
 #hstOES span {
	 background-color: #009E40;
	 padding: 10px 20px;
	 color: white;
	 border-radius: 10px;
	 font-size: 20px;
	 box-shadow: 0px 4px 5px rgba(0, 0, 0, 0.14), 0px 1px 10px rgba(0, 0, 0, 0.12), 0px 2px 4px rgba(0, 0, 0, 0.2);
}
 #dambao span {
	 background-color: #009E40;
	 padding: 10px 20px;
	 color: white;
	 border-radius: 10px;
	 font-size: 20px;
	 box-shadow: 0px 4px 5px rgba(0, 0, 0, 0.14), 0px 1px 10px rgba(0, 0, 0, 0.12), 0px 2px 4px rgba(0, 0, 0, 0.2);
}
 @media only screen and (max-width:768px){
	 #moDau {
		 margin-right: 10px;
		 margin-left: 10px;
	}
	 .cnleft {
		 padding: 0;
	}
	 #chuyenNghiep, #nhietHuyet, #tinhTe, #sangTao, .toiUu, #hst, .toiUu2 {
		 display: inline;
	}
	 .hst1 {
		 display: block;
	}
	 .part1, .part3 {
		 display: none;
	}
	 .ti-kh {
		 padding-left: 0;
	}
	 .para {
		 padding-left:0;
	}
	 #khachHang img {
		 margin-left: 0px;
	}
	 .nh1 {
		 width: 100%;
		 padding-left: 0;
	}
	 .nh2 {
		 width: 100%;
		 padding-right: 0;
	}
	 .tt1 {
		 width: 100%;
		 padding-left: 0;
		 padding-right: 0;
	}
	 .tt2 {
		 width: 100%;
		 padding-right: 0;
	}
	 .st1 {
		 width: 100%;
		 padding-right: 0;
		 padding-left: 0;
	}
	 .st2 {
		 width: 100%;
		 padding-right: 0;
	}
	 #toiUu1 {
		 padding-left:0;
		 padding-right:0;
	}
	 #hstOES span {
		 padding: 0px;
	}
	 #dambao span {
		 padding: 0px;
	}
	 .part2 {
		 width: 100%;
		 padding-top: 0px;
	}
	 .tu1 {
		 margin-bottom: 10px;
		 padding-right:20px;
		 width:100%;
	}
	 .tu2 {
		 width:100%;
		 padding-right:20px;
	}
}
/* USP */

/* nav */
@media (max-width: 767px) {
#menu-item-208 {
	visibility: hidden;
}	
}

.off-canvas-toggle {
    border: none;
    background: transparent;
    position:absolute;
    left:10px; 
    top:30px;
}
/* Category title */
 .category-title-fix {
	 margin: 0;
	 color: #FFF;
	 font-size: 32px;
}
/* Category title */
/* button tư vấn */
 .button-bar>a {
	 color: #fff;
	 text-decoration: none;
	 font-size: 15px;
	 font-weight: 500;
	 text-indent: 16px;
	 display: block;
	 line-height: 38px;
	 text-transform: uppercase;
}
 .button-bar {
	 position: absolute;
	 background: -webkit-linear-gradient(left, #34b401, #067901);
	 background: -o-linear-gradient(right, #34b401, #067901);
	 background: -moz-linear-gradient(right, #34b401, #067901);
	 background: linear-gradient(to right, #34b401, #067901);
	 height: 40px;
	 width: 148px;
	 line-height: 40px;
	 padding: 0 10px;
	 background-size: 100%;
	 cursor: pointer;
	 transition: all 0.8s;
	 -webkit-transition: all 0.8s;
	 z-index: 9;
	 box-shadow: 0 14px 28px rgb(0 0 0 / 25%), 0 10px 10px rgb(0 0 0 / 10%);
	 border-radius: 50px;
	 border: 2px solid white;
	 left: 33px;
	 bottom: 37px;
}
 .button-tu-van {
	 position: fixed;
	 bottom: 50px;
	 left: 0;
	 z-index: 999;
}
/* button tư vấn */
/* Fix tam thoi */
/* home banner*/
 .panel-title {
	 font-size: 14px;
}
 .intro-carousel.owl-carousel.owl-theme {
	 display: flex;
	 flex-flow: row wrap;
	 justify-content: center;
	 margin: 5px 0;
	 ;
