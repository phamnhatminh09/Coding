	border-radius: 3px;
	padding: 10px 15px;
	background: none;
	border: solid #ccc 1px;
}
.pagenavi a:hover {
	transition: smooth;
	transition-duration: 0.2;
	background: #444;
}
.pagenavi a.current:hover {
	background: rgba(0,129,88,1);
}








