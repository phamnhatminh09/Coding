<div id="homenews" class="clearfix">
    <div class="container">
    	<div class="row">
    		<div class="col-lg-8 col-md-8 col-sm-8 col-xs-12">
    			            		<div class="widget_bulletin boxwidth"><h3 class="widget-title"><span>Tin tức & Xu hướng</span></h3><div class="filter"><span class="active"><span class="active_text">Mới nhất</span> <span class="caret pull-right"></span></span><ul><li><a onclick="ajax_filter('0','Bài đăng mới nhất')">Bài đăng mới nhất</a></li><li><a onclick="ajax_filter('24','Cộng đồng E-learning')">Cộng đồng E-learning</a></li></ul></div>				<script>
            	
            		var filter = 'date';
            		//var filter = $('#filter').attr('data-sort');
            		
            		function ajax_filter(category_id,text_select) {
            			
            	    	$.ajax({ // Hàm ajax
            	            type : "post", //Phương thức truyền post hoặc get
            	            dataType : "html", //Dạng dữ liệu trả về xml, json, script, or html
            	            async: false,
            	            url : 'https://oes.vn/wp-admin/admin-ajax.php', // Nơi xử lý dữ liệu
            	            data : {
            	                action: "loadmore", //Tên action, dữ liệu gởi lên cho server
            	                category_id: category_id,
            	                filter: filter, // gởi số lượng bài viết đã hiển thị cho server
            	            },
            	            beforeSend: function(){
            	                // Có thể thực hiện công việc load hình ảnh quay quay trước khi đổ dữ liệu ra
            	            	$('#loader').removeClass('hidden');
            	            },
            	            success: function(response) {
                	            
            	            	$('.filter .active_text').text(text_select);
            	            	$('#homenews .boxwidth .row').empty();
            	                $('#homenews .boxwidth .row').html(response);
            	                $('#loader').addClass('hidden');
//             	                if(response == ''){
//             		                alert('All loaded');
//             		            }
            	            },
            	            error: function( jqXHR, textStatus, errorThrown ){
            	                //Làm gì đó khi có lỗi xảy ra
            	                console.log( 'The following error occured: ' + textStatus, errorThrown );
            	            }
            	       });
            		}
            		
            	
            </script>
